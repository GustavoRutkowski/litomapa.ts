{
  "name": "litomapa",
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "contributors": [
    "Enrico Garcia Alvarez",
    "Felipi Gabriel Haag Machado",
    "Gustavo Rutkowski Lara",
    "João Luís Venturini Fernandes",
    "Luan Siloé dos Santos Fernandes"
  ],
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run api:dev\" \"npm run web:dev\"",
    "prod": "concurrently \"npm run api:prod\" \"npm run web:prod\"",

    "api:dev": "concurrently \"npm run api-build:dev\" \"nodemon ./backend/dist/app.js\"",
    "api:prod": "npm run api-build:prod && node ./backend/dist/app.js",

    "migrate": "npx tsx ./backend/src/db/migrate.ts",

    "api-build:dev": "tsc -p tsconfig.backend.json --watch",
    "api-build:prod": "tsc -p tsconfig.backend.json",

    "web:dev": "concurrently \"npm run web-build:dev\" \"vite --config ./frontend/vite.config.ts\"",
    "web:prod": "npm run web-build:prod && vite preview --config ./frontend/vite.config.ts",
    
    "web-build:dev": "vite build --watch --config ./frontend/vite.config.ts",
    "web-build:prod": "vite build --config ./frontend/vite.config.ts",

    "lint": "npx eslint .",
    "lint:fix": "npx eslint . --fix",
    "format": "npx prettier --write .",
    "format:check": "npx prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write",
      "tsc --noEmit"
    ]
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.0",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "styled-components": "^6.3.11",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "@types/styled-components": "^5.1.36",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.14",
    "prettier": "^3.8.1",
    "sass": "^1.97.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
