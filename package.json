  "type": "module",
  "scripts": {
    "api:dev": "concurrently \"npm run api-build:dev\" \"nodemon ./backend/dist/app.js\"",
    "api:prod": "npm run api-build:prod && node ./backend/dist/app.js",

    "migrate": "npx tsx ./backend/db/migrate.ts",
  
    "api-build:dev": "tsc -p tsconfig.backend.json --watch",
    "api-build:prod": "tsc -p tsconfig.backend.json"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.0",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14"
  }
}
